ENVIRONMENT=development

# LLM + STT/TTS providers
OPENAI_API_KEY=sk-...
SARVAMAI_API_KEY=

# Postgres (Supabase pooler DSN). Must be an asyncpg-compatible driver URL.
DATABASE_URL=postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Vercel Blob — required only for VOICE replies (TTS audio upload).
BLOB_READ_WRITE_TOKEN=

# Optional per-agent model overrides (default: gpt-4o-mini)
# PUCHO_ROUTER_MODEL=gpt-4o-mini
# PUCHO_LEGAL_MODEL=gpt-4o-mini
# PUCHO_healthcare_MODEL=gpt-4o-mini
# PUCHO_FINANCIAL_MODEL=gpt-4o-mini
